# Copy this file to .env.local and fill in the values from your Supabase project
# Supabase dashboard: Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Comma-separated list of admin emails (no spaces)
# Example: NEXT_PUBLIC_ADMIN_EMAILS=me@example.com,friend@example.com
NEXT_PUBLIC_ADMIN_EMAILS=REPLACE_WITH_YOUR_ADMIN_EMAIL@example.com

# Cloudinary unsigned upload — sign up free at https://cloudinary.com/users/register/free
# Cloud name: top of your dashboard (e.g. dxyz1234).
# Upload preset: Settings → Upload → Upload presets → Add. Set "Signing Mode" to Unsigned.
# Used to upload submission images and avatars directly from the browser.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name-here
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset-here
