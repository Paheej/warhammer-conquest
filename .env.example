# Copy this file to .env.local and fill in the values from your Supabase project
# Supabase dashboard: Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Comma-separated list of admin emails (no spaces)
# Example: NEXT_PUBLIC_ADMIN_EMAILS=me@example.com,friend@example.com
NEXT_PUBLIC_ADMIN_EMAILS=REPLACE_WITH_YOUR_ADMIN_EMAIL@example.com
